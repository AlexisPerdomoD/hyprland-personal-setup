{
  "background": {
    "enabled": true
  },
  "general": {
    "apps": {
      "terminal": ["alacritty"],
      "audio": ["pavucontrol"],
      "editor": ["neovide"]
    }
  },
  "border": {
    "rounding": 4,
    "thickness": 2
  },
  "appearance": {
    "font": {
      "family": {
        "sans": "Terminess Nerd Font",
        "material": "Material Symbols Sharp",
        "mono": "Terminess Nerd Font Mono",
        "clock": "Terminess Nerd Font Mono"
      },
      "size": {
        "scale": 1
      }
    }
  },
  "bar": {
    "dragThreshold": 20,
    "externalAudioProgram": ["pavucontrol"],
    "persistent": false,
    "showOnHover": true,
    "status": {
      "showAudio": true,
      "showBattery": true,
      "showBluetooth": true,
      "showKbLayout": true,
      "showNetwork": true
    },
    "workspaces": {
      "activeIndicator": true,
      "activeLabel": "󰮯 ",
      "activeTrail": false,
      "label": "  ",
      "occupiedBg": false,
      "occupiedLabel": "󰮯 ",
      "rounded": true,
      "showWindows": true,
      "shown": 5
    }
  },
  "dashboard": {
    "enabled": true,
    "mediaUpdateInterval": 500,
    "visualiserBars": 45
  },
  "launcher": {
    "actionPrefix": ">",
    "dragThreshold": 50,
    "vimKeybinds": true,
    "enableDangerousActions": true,
    "maxShown": 8,
    "maxWallpapers": 9,
    "useFuzzy": {
      "apps": false,
      "actions": false,
      "schemes": false,
      "variants": false,
      "wallpapers": false
    }
  },
  "lock": {
    "maxNotifs": 5
  },
  "notifs": {
    "actionOnClick": true,
    "clearThreshold": 0.3,
    "defaultExpireTimeout": 5000,
    "expandThreshold": 20,
    "expire": true
  },
  "osd": {
    "hideDelay": 2000
  },
  "paths": {
    "mediaGif": "~/.config/caelestia/media.gif",
    "sessionGif": "~/.config/caelestia/session.gif",
    "wallpaperDir": "~/Documents/Wallpapers/"
  },
  "services": {
    "weatherLocation": "10,10",
    "useFahrenheit": false,
    "useTwelveHourClock": false
  },
  "session": {
    "dragThreshold": 30,
    "vimKeybinds": false,
    "commands": {
      "logout": ["loginctl", "terminate-user", ""],
      "shutdown": ["systemctl", "poweroff"],
      "hibernate": ["systemctl", "suspend"],
      "reboot": ["systemctl", "reboot"]
    }
  }
}
